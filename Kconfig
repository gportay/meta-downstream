config KAS_INCLUDE_MAIN
	string
	default "kas-project.yaml"

menu "General"
source "branches/Kconfig"
source "layers/Kconfig"
source "inherits/Kconfig"

config HAS_BB_HASHSERVE_DB_DIR
	bool "Use sstate to share multiple build directories"
	help
	  When BB_HASHSERVE is set to auto, bitbake will use a private
	  location inside a particular build directory for the sqlite
	  database file that holds hash equivalency data.

	  This variable allows using a different path, which can be
	  shared between multiple build directories and bitbake
	  instances that operate on them. This enables using a common
	  ${SSTATE_DIR} together with common hash equivalency data for
	  local builds, without having to separately manage a hash
	  equivalency server.

	  Note

	  This variable cannot be set to a NFS mount and bitbake will
	  error out then. The reason is that NFS implementations can
	  have file locking issues, which can cause data loss and
	  corruption when there are multiple writers operating on a file
	  at the same time as explained in
	  https://sqlite.org/faq.html#q5

	  https://docs.yoctoproject.org/bitbake/dev/bitbake-user-manual/bitbake-user-manual-ref-variables.html#term-BB_HASHSERVE_DB_DIR

config KAS_INCLUDE_HAS_BB_HASHSERVE_DB_DIR
	string
	depends on HAS_BB_HASHSERVE_DB_DIR
	default "bb-hashserve-db-dir.yaml"

config HAS_BB_NO_NETWORK
	bool "No network"
	help
	  Disables network access in the BitBake fetcher modules. With
	  this access disabled, any command that attempts to access the
	  network becomes an error.

	  Disabling network access is useful for testing source mirrors,
	  running builds when not connected to the Internet, and when
	  operating in certain kinds of firewall environments.

	  https://docs.yoctoproject.org/dev/ref-manual/variables.html#term-BB_NO_NETWORK

config KAS_INCLUDE_HAS_BB_NO_NETWORK
	string
	depends on HAS_BB_NO_NETWORK
	default "bb-no-network.yaml"

endmenu

