# short-description: Create Raspberry Pi SD card image with separate hash
# dm-verity
# long-description: Creates a partitioned SD card image for use with
# Raspberry Pi. Boot files are located in the first vfat partition.
# A dm-verity variant of the regular wks for Raspberry Pi machines. We need to
# fetch the partition images from the IMGDEPLOYDIR as the rootfs source plugin
# will not recreate the exact block device corresponding with the hash tree. We
# must not alter the label or any other setting on the image.
# Based on meta-raspberrypi's sdimage-raspberrypi.wks and meta-security's
# systemd-bootdisk-dmverity-hash.wks.in files
#
# This .wks only works with the dm-verity-img class and separate hash data
# (DM_VERITY_SEPARATE_HASH).

part /boot --source bootimg-partition --ondisk mmcblk0 --fstype=vfat --label boot --active --align 4096 --size 100
# include the root+hash part with the dynamic hash/UUIDs from the build.
include ${STAGING_VERITY_DIR}/${IMAGE_BASENAME}.${DM_VERITY_IMAGE_TYPE}.wks.in
bootloader --ptable gpt
